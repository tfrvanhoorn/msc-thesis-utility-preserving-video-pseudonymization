Bootstrap: docker
From: nvidia/cuda:12.4.1-cudnn-devel-ubuntu22.04

%files
    external_libraries/EMO-AffectNetModel/requirements.txt /opt/emo_affectnet_requirements.txt

%post
    export DEBIAN_FRONTEND=noninteractive
    set -eux

    apt-get update && apt-get install -y --no-install-recommends \
        build-essential cmake git curl wget vim tmux bzip2 unzip g++ \
        ca-certificates ffmpeg libx264-dev imagemagick libnss3-dev \
        python3.10 python3.10-dev python3.10-distutils python3-distutils \
        libgl1-mesa-glx libglib2.0-0
    apt-get clean && rm -rf /var/lib/apt/lists/*

    update-alternatives --install /usr/bin/python python /usr/bin/python3.10 1

    curl https://bootstrap.pypa.io/get-pip.py -o get-pip.py
    python get-pip.py
    rm get-pip.py

    # Pin numpy<2 first so nothing transitively upgrades us into the numpy-2
    # ABI break that crashes TensorFlow 2.17 on import.
    pip install --no-cache-dir "numpy<2"

    # Install EMO-AffectNetModel requirements without torch / tensorflow /
    # opencv-python — we install all three explicitly with the right wheels.
    iconv -f UTF-16 -t UTF-8 /opt/emo_affectnet_requirements.txt > /tmp/req.utf8.txt
    grep -vE '^[[:space:]]*torch[[:space:]]+torchvision[[:space:]]+torchaudio([[:space:]].*)?$' /tmp/req.utf8.txt | \
    grep -vE '^[[:space:]]*tensorflow(-gpu|-cpu)?([[:space:]]*[<>=!~].*)?[[:space:]]*$' | \
    grep -vE '^[[:space:]]*opencv-(python|contrib-python)([[:space:]]*[<>=!~].*)?[[:space:]]*$' \
        > /tmp/req.filtered.txt
    pip install --no-cache-dir -r /tmp/req.filtered.txt

    # CUDA-bundled TF, cu124 torch, jax compatible with TF 2.17's ml_dtypes,
    # and a numpy-1-compatible opencv. opencv-python-headless 4.11+ requires
    # numpy>=2, so pin below that.
    pip install --no-cache-dir torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu124
    pip install --no-cache-dir "tensorflow[and-cuda]==2.17.0"
    pip install --no-cache-dir "jax<0.4.36" "jaxlib<0.4.36"
    pip install --no-cache-dir "opencv-python-headless<4.11"

    # Re-pin numpy<2 in case anything above tried to upgrade.
    pip install --no-cache-dir --force-reinstall "numpy<2" pandas tqdm

    rm -f /tmp/req.filtered.txt /tmp/req.utf8.txt

%environment
    export LC_ALL=C
    export CUDA_HOME=/usr/local/cuda
    export CUDA_PATH=/usr/local/cuda
    export PATH=/usr/local/cuda/bin:$PATH
    export LD_LIBRARY_PATH=/usr/local/cuda/lib64:$LD_LIBRARY_PATH
    export TORCH_EXTENSIONS_DIR=/tmp/torch_extensions
    export NVIDIA_VISIBLE_DEVICES=all
    export TF_FORCE_GPU_ALLOW_GROWTH=true
    export XLA_FLAGS=--xla_gpu_cuda_data_dir=/usr/local/cuda
    # If anything in the user's home accidentally shadows site-packages
    # (as just happened with the tmpfs fallback), this guarantees the
    # container's deps win.
    export PYTHONNOUSERSITE=1

%runscript
    exec python "$@"