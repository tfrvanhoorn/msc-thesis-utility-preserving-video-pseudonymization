Bootstrap: docker
From: nvidia/cuda:12.4.1-cudnn-devel-ubuntu22.04

%files
    external_libraries/EMO-AffectNetModel/requirements.txt /opt/emo_affectnet_requirements.txt

%post
    export DEBIAN_FRONTEND=noninteractive
    set -eux

    # 1. Install system dependencies for Python 3.10 (no recommends to avoid openssh-client pull-in)
    apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        cmake \
        git \
        curl \
        wget \
        vim \
        tmux \
        bzip2 \
        unzip \
        g++ \
        ca-certificates \
        ffmpeg \
        libx264-dev \
        imagemagick \
        libnss3-dev \
        python3.10 \
        python3.10-dev \
        python3.10-distutils \
        python3-distutils \
        libgl1-mesa-glx \
        libglib2.0-0

    # Clean apt caches to reduce image size and avoid stale lists
    apt-get clean && rm -rf /var/lib/apt/lists/*

    # 2. Set Python 3.10 as the default 'python'
    update-alternatives --install /usr/bin/python python /usr/bin/python3.10 1

    # 3. Install pip using the standard bootstrap script
    curl https://bootstrap.pypa.io/get-pip.py -o get-pip.py
    python get-pip.py
    rm get-pip.py

    # 4. Install EMO-AffectNetModel requirements for emotion recognition.
    # Normalize file encoding, split out the torch install line, and install it explicitly.
    iconv -f UTF-16 -t UTF-8 /opt/emo_affectnet_requirements.txt > /tmp/emo_affectnet_requirements.utf8.txt
    grep -vE '^[[:space:]]*torch[[:space:]]+torchvision[[:space:]]+torchaudio([[:space:]].*)?$' \
        /tmp/emo_affectnet_requirements.utf8.txt > /tmp/emo_affectnet_requirements.filtered.txt
    pip install --no-cache-dir -r /tmp/emo_affectnet_requirements.filtered.txt
    pip install --no-cache-dir torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu124
    rm -f /tmp/emo_affectnet_requirements.filtered.txt /tmp/emo_affectnet_requirements.utf8.txt

    # 5. Install extra runtime dependencies used by the emotion recognition code.
    pip install --no-cache-dir numpy pandas tqdm

    # 6. Cleanup

%environment
    export LC_ALL=C
    export CUDA_HOME=/usr/local/cuda
    export CUDA_PATH=/usr/local/cuda
    export PATH=/usr/local/cuda/bin:$PATH
    export LD_LIBRARY_PATH=/usr/local/lib/python3.10/dist-packages/torch/lib:/usr/local/cuda/lib64:$LD_LIBRARY_PATH
    export TORCH_EXTENSIONS_DIR=/tmp/torch_extensions
    export NVIDIA_VISIBLE_DEVICES=all

%runscript
    exec python "$@"
