Bootstrap: docker
From: nvidia/cuda:11.8.0-cudnn8-devel-ubuntu20.04

%files
    requirements.txt /opt/requirements.txt
    external_libraries/imaginaire/imaginaire/third_party /opt/imaginaire/imaginaire/third_party
    external_libraries/imaginaire/imaginaire/model_utils/gancraft/voxlib /opt/imaginaire/imaginaire/model_utils/gancraft/voxlib

%post
    export DEBIAN_FRONTEND=noninteractive
    set -eux

    # 1. Install system dependencies for Python 3.8 (no recommends to avoid openssh-client pull-in)
    apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        cmake \
        git \
        curl \
        wget \
        vim \
        tmux \
        bzip2 \
        unzip \
        g++ \
        ca-certificates \
        ffmpeg \
        libx264-dev \
        imagemagick \
        libnss3-dev \
        python3.8 \
        python3.8-dev \
        python3.8-distutils \
        python3-distutils \
        libgl1-mesa-glx \
        libglib2.0-0

    # Clean apt caches to reduce image size and avoid stale lists
    apt-get clean && rm -rf /var/lib/apt/lists/*

    # 2. Set Python 3.8 as the default 'python'
    update-alternatives --install /usr/bin/python python /usr/bin/python3.8 1
    
    # 3. Install pip using the LEGACY 3.8 bootstrap script
    # The URL is specifically for Python 3.8 support
    curl https://bootstrap.pypa.io/pip/3.8/get-pip.py -o get-pip.py
    python get-pip.py
    rm get-pip.py

    # 4. Install PyTorch ecosystem for CUDA 11.8 (must match nvcc/CUDA runtime)
    pip install --no-cache-dir \
        torch==2.4.1+cu118 \
        torchvision==0.19.1+cu118 \
        torchaudio==2.4.1+cu118 \
        --index-url https://download.pytorch.org/whl/cu118

    # 5. Install dlib with conservative build settings to avoid OOM during image build.
    # Try wheel first; if source build is needed, force low parallelism and disable CUDA for dlib.
    export CMAKE_BUILD_PARALLEL_LEVEL=2
    export MAX_JOBS=2
    export CMAKE_ARGS="-DDLIB_USE_CUDA=OFF"
    pip install --no-cache-dir dlib || pip install --no-cache-dir --no-binary=:all: dlib

    # 6. Install the remaining requirements (skip dlib to prevent reinstall).
    grep -vE '^[[:space:]]*dlib([[:space:]]*(#.*)?)?$' /opt/requirements.txt > /tmp/requirements.no-dlib.txt
    pip install --no-cache-dir -r /tmp/requirements.no-dlib.txt
    rm -f /tmp/requirements.no-dlib.txt

    # 7. Build imaginaire custom CUDA/C++ extensions (mirrors scripts/build_docker.sh).
    export CUDA_VERSION=$(nvcc --version | grep -Po "(\d+\.)+\d+" | head -1)

        # Torch 2.x extensions require C++17. Imaginaire third-party setup.py files
        # still default to C++14 in this snapshot, so patch them before building.
        find /opt/imaginaire/imaginaire/third_party -name setup.py -type f -print0 | \
            xargs -0 sed -i 's/-std=c++14/-std=c++17/g'

    for p in correlation channelnorm resample2d bias_act upfirdn2d; do
        cd /opt/imaginaire/imaginaire/third_party/${p}
        rm -rf build dist *-info
        python setup.py install
    done

    # 8. Compile GANcraft libraries.
    cd /opt/imaginaire/imaginaire/model_utils/gancraft/voxlib
    make
    
    # 9. Cleanup
    unset CMAKE_BUILD_PARALLEL_LEVEL MAX_JOBS CMAKE_ARGS

%environment
    export LC_ALL=C
    export CUDA_HOME=/usr/local/cuda
    export CUDA_PATH=/usr/local/cuda
    export PATH=/usr/local/cuda/bin:$PATH
    export LD_LIBRARY_PATH=/usr/local/cuda/lib64:$LD_LIBRARY_PATH
    export TORCH_EXTENSIONS_DIR=/tmp/torch_extensions
    export NVIDIA_VISIBLE_DEVICES=all

%runscript
    exec python "$@"