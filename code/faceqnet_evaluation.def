Bootstrap: docker
From: python:3.10-slim-bookworm

%post
    set -eux

    # Minimal system libs for opencv-headless + downloads
    apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

    # Python deps — minimum stack to run FaceQnet end-to-end
    pip install --no-cache-dir --upgrade pip
    pip install --no-cache-dir \
        "tensorflow-cpu==2.15.1" \
        "numpy>=1.23,<2.0" \
        "opencv-python-headless==4.10.0.84" \
        "mtcnn==0.1.1" \
        "scipy>=1.10" \
        "tqdm"

%environment
    export TF_CPP_MIN_LOG_LEVEL=3
    export PYTHONUNBUFFERED=1

%labels
    Purpose FaceQnet face realism evaluation for pseudonymization pipelines
    Python  3.10
    TF      2.15.1 (CPU)